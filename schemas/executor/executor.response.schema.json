{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.aillium.dev/executor/executor.response.schema.json",
  "title": "Executor Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_type",
    "schema_version",
    "task_id",
    "response_id",
    "trace_id",
    "completed_at",
    "status",
    "result"
  ],
  "properties": {
    "contract_type": {
      "const": "executor.response"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0\\.0$"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "worker_id": {
      "type": "string",
      "minLength": 1
    },
    "response_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "executor_type": {
      "type": "string",
      "enum": ["generic", "agent", "tool", "job"]
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["succeeded", "failed", "cancelled", "timed_out"]
    },
    "timing": {
      "$ref": "executor.common.schema.json#/$defs/timing"
    },
    "cost": {
      "$ref": "executor.common.schema.json#/$defs/cost"
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output"],
      "properties": {
        "output": {
          "type": "object"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "executor.common.schema.json#/$defs/artifact_ref"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "executor.common.schema.json#/$defs/message"
          }
        }
      }
    },
    "error": {
      "$ref": "executor.common.schema.json#/$defs/error"
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "succeeded"
          }
        }
      },
      "then": {
        "not": {
          "required": ["error"]
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "enum": ["failed", "cancelled", "timed_out"]
          }
        }
      },
      "then": {
        "required": ["error"]
      }
    }
  ]
}
