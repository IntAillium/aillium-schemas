{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.aillium.dev/openclaw/runtime.schema.json",
  "title": "OpenClaw Runtime and Orchestration Contracts",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/runtime_dispatch" },
    { "$ref": "#/$defs/runtime_result" },
    { "$ref": "#/$defs/session_compaction_checkpoint" },
    { "$ref": "#/$defs/runtime_session_patch" },
    { "$ref": "#/$defs/plugin_approval_request" }
  ],
  "$defs": {
    "runtime_dispatch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_type",
        "schema_version",
        "task_id",
        "worker_id",
        "tenant_id",
        "trace_id",
        "created_at",
        "input"
      ],
      "properties": {
        "contract_type": { "const": "openclaw.runtime.dispatch" },
        "schema_version": { "type": "string", "pattern": "^1\\.0\\.0$" },
        "task_id": { "type": "string", "minLength": 1 },
        "worker_id": { "type": "string", "minLength": 1 },
        "tenant_id": { "type": "string", "minLength": 1 },
        "trace_id": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "format": "date-time" },
        "deadline_at": { "type": "string", "format": "date-time" },
        "input": {
          "type": "object",
          "additionalProperties": false,
          "required": ["task_type", "payload"],
          "properties": {
            "task_type": { "type": "string", "minLength": 1 },
            "payload": { "type": "object" },
            "context": { "type": "object", "additionalProperties": true }
          }
        }
      }
    },
    "session_compaction_reason": {
      "type": "string",
      "enum": ["manual", "auto-threshold", "overflow-retry", "timeout-retry"]
    },
    "exec_host": {
      "type": "string",
      "enum": ["sandbox", "gateway", "node", "auto"]
    },
    "plugin_approval_decision": {
      "type": "string",
      "enum": ["approved", "denied"]
    },
    "tools_effective_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "source"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "source": { "type": "string", "enum": ["core", "plugin", "channel"] },
        "plugin_id": { "type": "string" },
        "channel_id": { "type": "string" }
      }
    },
    "session_compaction_checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_type",
        "checkpoint_id",
        "session_key",
        "session_id",
        "created_at",
        "reason",
        "tokens_before",
        "tokens_after"
      ],
      "properties": {
        "contract_type": { "const": "openclaw.session.compaction_checkpoint" },
        "checkpoint_id": { "type": "string", "minLength": 1 },
        "session_key": { "type": "string", "minLength": 1 },
        "session_id": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "format": "date-time" },
        "reason": { "$ref": "#/$defs/session_compaction_reason" },
        "tokens_before": { "type": "integer" },
        "tokens_after": { "type": "integer" },
        "summary": { "type": "string" }
      }
    },
    "runtime_session_patch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract_type", "key"],
      "properties": {
        "contract_type": { "const": "openclaw.session.patch" },
        "key": { "type": "string", "minLength": 1 },
        "model": { "type": "string" },
        "auth_profile_id": { "type": "string" },
        "auth_profile_source": { "type": "string", "enum": ["auto", "user"] },
        "exec_host": { "$ref": "#/$defs/exec_host" }
      }
    },
    "plugin_approval_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract_type", "plugin_id", "title", "description"],
      "properties": {
        "contract_type": { "const": "openclaw.plugin_approval.request" },
        "plugin_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "severity": { "type": "string" },
        "tool_name": { "type": "string" },
        "agent_id": { "type": "string" },
        "session_key": { "type": "string" },
        "timeout_ms": { "type": "number" }
      }
    },
    "tools_effective_group": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "source", "tools"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "source": { "type": "string" },
        "tools": {
          "type": "array",
          "items": { "$ref": "#/$defs/tools_effective_entry" }
        }
      }
    },
    "runtime_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_type",
        "schema_version",
        "task_id",
        "worker_id",
        "tenant_id",
        "trace_id",
        "completed_at",
        "status",
        "result"
      ],
      "properties": {
        "contract_type": { "const": "openclaw.runtime.result" },
        "schema_version": { "type": "string", "pattern": "^1\\.0\\.0$" },
        "task_id": { "type": "string", "minLength": 1 },
        "worker_id": { "type": "string", "minLength": 1 },
        "tenant_id": { "type": "string", "minLength": 1 },
        "trace_id": { "type": "string", "minLength": 1 },
        "completed_at": { "type": "string", "format": "date-time" },
        "status": {
          "type": "string",
          "enum": ["succeeded", "failed", "cancelled", "timed_out"]
        },
        "result": {
          "type": "object",
          "additionalProperties": false,
          "required": ["output"],
          "properties": {
            "output": { "type": "object" },
            "artifacts": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["uri"],
                "properties": {
                  "uri": { "type": "string", "minLength": 1 },
                  "content_type": { "type": "string" },
                  "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
                }
              }
            }
          }
        },
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string", "minLength": 1 },
            "message": { "type": "string", "minLength": 1 },
            "retryable": { "type": "boolean" }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "succeeded" } } },
          "then": { "not": { "required": ["error"] } }
        },
        {
          "if": {
            "properties": {
              "status": { "enum": ["failed", "cancelled", "timed_out"] }
            }
          },
          "then": { "required": ["error"] }
        }
      ]
    }
  }
}
