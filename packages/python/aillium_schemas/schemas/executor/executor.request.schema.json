{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.aillium.dev/executor/executor.request.schema.json",
  "title": "Executor Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_type",
    "schema_version",
    "task_id",
    "trace_id",
    "tenant_id",
    "created_at",
    "input"
  ],
  "properties": {
    "contract_type": {
      "const": "executor.request"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0\\.0$"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "worker_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "executor_type": {
      "type": "string",
      "enum": ["generic", "agent", "tool", "job"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "deadline_at": {
      "type": "string",
      "format": "date-time"
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_ref"],
      "properties": {
        "policy_ref": {
          "type": "string",
          "minLength": 1
        },
        "max_runtime_ms": {
          "type": "integer",
          "minimum": 1
        },
        "max_cost_units": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_type", "payload"],
      "properties": {
        "task_type": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object"
        },
        "attachments": {
          "type": "array",
          "items": {
            "$ref": "executor.common.schema.json#/$defs/artifact_ref"
          }
        },
        "context": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
