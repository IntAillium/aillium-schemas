{
  "name": "@aillium/schemas",
  "version": "0.1.0",
  "private": false,
  "workspaces": [
    "packages/typescript",
    "packages/python"
  ],
  "main": "packages/typescript/dist/index.js",
  "types": "packages/typescript/dist/index.d.ts",
  "exports": {
